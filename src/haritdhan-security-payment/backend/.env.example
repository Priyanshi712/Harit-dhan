# ─── SERVER ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE ─────────────────────────────────────────────
# Replace with your MongoDB connection string
# Free cluster: https://cloud.mongodb.com
MONGODB_URI=mongodb://localhost:27017/haritdhan

# ─── JWT ──────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── RAZORPAY ─────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Use test keys during development (prefix: rzp_test_)
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_SECRET

# ─── FRONTEND ─────────────────────────────────────────────
# Your React app URL (for CORS)
FRONTEND_URL=http://localhost:3000
